<Window x:Class="Lab22.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab22"
        mc:Ignorable="d"
        Title="Lab22" Height="450" Width="800">
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Executed"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Executed"/>
    </Window.CommandBindings>
    <Grid>
        <ToolBar HorizontalAlignment="Center" Height="33" VerticalAlignment="Top" Width="800">
            <Button x:Name="openButton" HorizontalAlignment="Left" VerticalAlignment="Top" Command="ApplicationCommands.Open">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;" FontSize="20" />
            </Button>
            <Button x:Name="saveButton" VerticalAlignment="Top" Command="ApplicationCommands.Save">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE105;" FontSize="20" />
            </Button>
            <Separator/>
            <ToggleButton x:Name="boldButton" HorizontalAlignment="Left" Command="EditingCommands.ToggleBold">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8DD;" FontSize="20" />
            </ToggleButton>
            <ToggleButton x:Name="italicButton" HorizontalAlignment="Left" Command="EditingCommands.ToggleItalic">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8DB;" FontSize="20" />
            </ToggleButton>
            <ToggleButton x:Name="underlineButton" HorizontalAlignment="Left" Command="EditingCommands.ToggleUnderline">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8DC;" FontSize="20" />
            </ToggleButton>
            <Separator/>
            <ComboBox x:Name="fontComboBox" Width="150" SelectionChanged="fontComboBox_SelectionChanged"/>
            <ComboBox x:Name="sizeComboBox" Width="50" HorizontalAlignment="Left" IsEditable="True" TextBoxBase.TextChanged="sizeComboBox_TextChanged"/>
            <Button HorizontalAlignment="Left" VerticalAlignment="Center" Name="leftAlignButton" Command="EditingCommands.AlignLeft">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E4;" FontSize="20"/>
            </Button>
            <Button HorizontalAlignment="Left" VerticalAlignment="Center" Name="centerAlignButton" Command="EditingCommands.AlignCenter">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E3;" FontSize="20"/>
            </Button>
            <Button HorizontalAlignment="Left" VerticalAlignment="Center" Name="rightAlignButton" Command="EditingCommands.AlignRight">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E2;" FontSize="20"/>
            </Button>
            <Button HorizontalAlignment="Left" VerticalAlignment="Center" Name="insertPictureButton" Click="insertPictureButton_Click">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEB9F;"/>
            </Button>
        </ToolBar>
        <TabControl x:Name="fileTabControl" Margin="0,33,0,0">
        </TabControl>


    </Grid>
</Window>
